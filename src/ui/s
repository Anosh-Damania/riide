use std::path::PathBuf;

use crate::state::workspace::WorkspaceState;

/// A single entry in the pre-computed directory tree.
/// The orchestrator builds this using `rebuild_dir_tree`.
/// The UI never does I/O — it only reads this cached structure.
#[derive(Clone)]
pub struct DirEntry {
    pub path: PathBuf,
    pub name: String,
    pub is_dir: bool,
    pub children: Vec<DirEntry>,
}

/// Events that can be emitted by the file explorer side panel.
pub enum ExplorerEvent {
    OpenFile(PathBuf),
    ToggleDir(PathBuf),
    GoToParent,
}

/// Render the file explorer side panel with a lazy-loaded recursive tree.
pub fn render_file_explorer(
    workspace: &mut WorkspaceState,
    root_entries: &[DirEntry],
    ui: &mut egui::Ui,
) -> Option<ExplorerEvent> {
    let mut event: Option<ExplorerEvent> = None;

    ui.label(format!("📁 {}", workspace.current_dir().display()));

    if ui.button("⬆  ..").clicked() {
        event = Some(ExplorerEvent::GoToParent);
    }
    ui.separator();

    egui::ScrollArea::vertical().show(ui, |ui| {
        for entry in root_entries {
            let ev = render_tree_entry(entry, workspace, ui);
            if ev.is_some() {
                event = ev;
            }
        }
    });

    event
}

fn render_tree_entry(
    entry: &DirEntry,
    workspace: &WorkspaceState,
    ui: &mut egui::Ui,
) -> Option<ExplorerEvent> {
    if entry.is_dir {
        let expanded = workspace.is_expanded(&entry.path);
        let mut ev: Option<ExplorerEvent> = None;

        let response = egui::CollapsingHeader::new(&entry.name)
            .id_source(&entry.path)
            .open(Some(expanded))
            .show(ui, |ui| {
                for child in &entry.children {
                    if let Some(e) = render_tree_entry(child, workspace, ui) {
                        ev = e;
                    }
                }
            });

        // If the user clicked the header, toggle expansion
        if response.header_response.clicked() {
            return Some(ExplorerEvent::ToggleDir(entry.path.clone()));
        }

        ev
    } else {
        let label = egui::RichText::new(format!("📄  {}", entry.name));
        if ui
            .label(label)
            .interact(egui::Sense::click())
            .on_hover_cursor(egui::CursorIcon::PointingHand)
            .clicked()
        {
            return Some(ExplorerEvent::OpenFile(entry.path.clone()));
        }
        None
    }
}